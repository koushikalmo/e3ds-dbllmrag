# ============================================================
# Eagle 3D Streaming Query System — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ── MongoDB Connection Strings ───────────────────────────────
MONGODB_URI_STREAM=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI_APPCONFIGS=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

STREAM_DB_NAME=stream-datastore
APPCONFIGS_DB_NAME=appConfigs
DEFAULT_STREAM_COLLECTION=Apr_2026

# ── Local LLM — Ollama ───────────────────────────────────────
# Prerequisites:
#   1. Install Ollama: https://ollama.com
#   2. Start it:      ollama serve
#   3. Pull a model:  ollama pull qwen2.5-coder:7b
#
# 8GB GPU recommendations (pick one):
#   qwen2.5-coder:7b   (best for JSON/query generation, ~4.7GB VRAM)
#   mistral:7b         (good general model, ~4.1GB VRAM)
#   llama3.1:8b        (strong general purpose, ~4.7GB VRAM)
#
# 16GB GPU recommendations (after upgrade):
#   qwen2.5-coder:14b  (significantly better quality, ~9GB VRAM)
#   codestral:22b      (state-of-the-art, needs Q4 quant, ~13GB)
#
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Context window for the local model.
# Vector RAG keeps the full prompt under 2,000 tokens so 8192 is
# safe with 6,000 tokens of headroom left for the generated pipeline.
OLLAMA_NUM_CTX=8192

# Embedding model — used for semantic RAG (schema field retrieval +
# example similarity). Pull once with: ollama pull nomic-embed-text
# If not pulled, the app falls back to keyword search automatically.
OLLAMA_EMBED_MODEL=nomic-embed-text

# How many times to retry if the LLM produces invalid output.
# Each retry sends the error back to the model for self-correction.
# 3 is a good default.
LLM_MAX_RETRIES=3

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
